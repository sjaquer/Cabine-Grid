rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userDocPath());
    }

    function getRole() {
      return hasUserProfile() ? get(userDocPath()).data.role : null;
    }

    function isAdmin() {
      return getRole() == 'admin';
    }

    function isManager() {
      return getRole() == 'manager';
    }

    function isOperator() {
      return getRole() == 'operator';
    }

    function isViewOnly() {
      return getRole() == 'view-only';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    function canOperate() {
      return isAdminOrManager() || isOperator();
    }

    function hasNonNegativeCurrentStock() {
      return request.resource.data.currentStock is number && request.resource.data.currentStock >= 0;
    }

    function hasNonNegativeStock() {
      return request.resource.data.stock is number && request.resource.data.stock >= 0;
    }

    function userCanAccessLocation(locationId) {
      return isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.locationIds.hasAny([locationId]);
    }

    function machineLocationId() {
      return get(/databases/$(database)/documents/machines/$(resource.data.machineId)).data.locationId;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdminOrManager());
      allow list: if isAdminOrManager();

      // Permite bootstrap del perfil propio al iniciar sesión por primera vez.
      allow create: if isSignedIn() && (
        request.auth.uid == userId || isAdminOrManager()
      );

      // El propio usuario puede actualizar datos básicos (no rol).
      allow update: if isSignedIn() && (
        isAdminOrManager() ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role
        )
      );

      allow delete: if isAdmin();
    }

    match /machines/{machineId} {
      allow read: if isSignedIn();
      allow create, update, delete: if canOperate();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminOrManager();
    }

    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminOrManager();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if canOperate();
      allow update: if canOperate();
      allow delete: if isAdminOrManager();
    }

    match /inventory/{inventoryId} {
      allow read: if isSignedIn();
      allow create, update: if canOperate() && hasNonNegativeCurrentStock();
      allow delete: if isAdminOrManager();
    }

    match /stockMovements/{movementId} {
      allow read: if isSignedIn();
      allow create: if canOperate();
      allow update, delete: if isAdminOrManager();
    }

    match /shifts/{shiftId} {
      allow read: if isSignedIn() && (isAdminOrManager() || request.auth.uid == resource.data.operatorId);
      allow create: if canOperate();
      allow update: if canOperate() && (request.auth.uid == resource.data.operatorId || isAdminOrManager());
      allow delete: if isAdminOrManager();
    }

    match /inventoryMovements/{movementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if canOperate();
    }

    match /shiftClosures/{closureId} {
      allow read: if isAdminOrManager();
      allow create: if canOperate();
      allow update, delete: if isAdmin();
    }

    match /receiptCounters/{counterId} {
      allow read: if isSignedIn();
      allow create, update: if canOperate();
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdminOrManager();
      allow create: if canOperate();
      allow update, delete: if isAdmin();
    }

    // Bloquea cualquier colección no prevista.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
