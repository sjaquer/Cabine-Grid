rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userDocPath());
    }

    // Phase 3: Try custom claims first (set by onUserProfileWrite Cloud Function),
    // fallback to Firestore document read for backward compatibility
    function getRole() {
      return ('role' in request.auth.token)
        ? request.auth.token.role
        : (hasUserProfile() ? get(userDocPath()).data.role : null);
    }

    function isAdmin() {
      return getRole() == 'admin';
    }

    function isManager() {
      return getRole() == 'manager';
    }

    function isOperator() {
      return getRole() == 'operator';
    }

    function isViewOnly() {
      return getRole() == 'view-only';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    function canOperate() {
      return isAdminOrManager() || isOperator();
    }

    function hasNonNegativeCurrentStock() {
      return request.resource.data.currentStock is number && request.resource.data.currentStock >= 0;
    }

    function hasNonNegativeStock() {
      return request.resource.data.stock is number && request.resource.data.stock >= 0;
    }

    function hasValidCustomerBaseData() {
      return request.resource.data.customerCode is string &&
        request.resource.data.customerCode.size() > 0 &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() > 1;
    }

    function hasValidCardTemplate() {
      return request.resource.data.name is string && request.resource.data.name.size() > 0
        && request.resource.data.type is string;
    }

    function hasValidSaleData() {
      return request.resource.data.amount is number && 
             request.resource.data.amount > 0 &&
             request.resource.data.paymentMethod is string;
    }

    // Phase 3: Use custom claims for location check when available
    function userCanAccessLocation(locationId) {
      return isAdminOrManager() || (
        isOperator() && (
          locationId != null && (
            // Try custom claims first (no extra read)
            (('locationIds' in request.auth.token) && request.auth.token.locationIds is list && request.auth.token.locationIds.hasAny([locationId])) ||
            // Fallback to Firestore read
            (get(userDocPath()).data.locationIds is list && get(userDocPath()).data.locationIds.hasAny([locationId]))
          )
        )
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdminOrManager());
      allow list: if isAdminOrManager();

      // Bootstrap del perfil propio con restricciones para evitar escalamiento.
      allow create: if isSignedIn() && (
        isAdminOrManager() ||
        (
          request.auth.uid == userId &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.role in ['operator', 'view-only'] &&
          request.resource.data.isActive == true &&
          request.resource.data.email is string
        )
      );

      // El propio usuario solo puede cambiar datos no privilegiados.
      allow update: if isSignedIn() && (
        isAdminOrManager() ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.locationIds == resource.data.locationIds &&
          request.resource.data.isActive == resource.data.isActive &&
          request.resource.data.email == resource.data.email &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance']) || request.resource.data.balance >= 0)
        )
      );

      allow delete: if isAdmin();
    }

    match /stations/{machineId} {
      allow read: if isSignedIn() && userCanAccessLocation(resource.data.locationId);
      allow create, update: if canOperate() && userCanAccessLocation(request.resource.data.locationId);
      allow delete: if isAdmin() && userCanAccessLocation(resource.data.locationId);
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOrManager();
      allow delete: if isAdmin();
    }

    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOrManager();
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if canOperate() && hasValidCustomerBaseData();
      allow update: if canOperate() && hasValidCustomerBaseData() && (
        // inventoryCards must be a list when present
        (!request.resource.data.keys().hasAny(['inventoryCards']) || request.resource.data.inventoryCards is list)
      );
      allow delete: if isAdmin();
    }

    // Card templates used by admin to create pre-made cards
    match /cardTemplates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isAdminOrManager() && hasValidCardTemplate();
      allow update: if isAdminOrManager() && hasValidCardTemplate();
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn() && userCanAccessLocation(resource.data.locationId);
      allow create, update: if canOperate() && userCanAccessLocation(request.resource.data.locationId) && hasValidSaleData();
      allow delete: if isAdmin() && userCanAccessLocation(resource.data.locationId);
    }

    match /inventory/{inventoryId} {
      allow read: if isSignedIn() && userCanAccessLocation(resource.data.locationId);
      allow create, update: if canOperate() && hasNonNegativeCurrentStock() && userCanAccessLocation(request.resource.data.locationId);
      allow delete: if isAdmin() && userCanAccessLocation(resource.data.locationId);
    }

    match /stockMovements/{movementId} {
      allow read: if isSignedIn() && userCanAccessLocation(resource.data.locationId);
      allow create: if canOperate() && userCanAccessLocation(request.resource.data.locationId);
      allow update, delete: if isAdmin() && userCanAccessLocation(resource.data.locationId);
    }

    match /shifts/{shiftId} {
      allow read: if isSignedIn() && (isAdminOrManager() || request.auth.uid == resource.data.operatorId);
      allow create: if canOperate();
      allow update: if canOperate() && (request.auth.uid == resource.data.operatorId || isAdminOrManager());
      allow delete: if isAdmin();
    }

    match /inventory_movements/{movementId} {
      allow read: if isSignedIn() && userCanAccessLocation(resource.data.locationId);
      allow create, update: if canOperate() && userCanAccessLocation(request.resource.data.locationId);
      allow delete: if isAdmin() && userCanAccessLocation(resource.data.locationId);
    }

    match /inventoryDiscrepancies/{discrepancyId} {
      allow read: if isSignedIn() && userCanAccessLocation(resource.data.locationId);
      allow create, update: if canOperate() && userCanAccessLocation(request.resource.data.locationId);
      allow delete: if isAdmin() && userCanAccessLocation(resource.data.locationId);
    }

    // NOTE: inventoryMovements (camelCase) removed — use inventory_movements (snake_case) only.

    match /shiftClosures/{closureId} {
      allow read: if isAdminOrManager() && userCanAccessLocation(resource.data.locationId);
      allow create: if canOperate() && userCanAccessLocation(request.resource.data.locationId);
      allow update, delete: if isAdmin() && userCanAccessLocation(resource.data.locationId);
    }

    match /receiptCounters/{counterId} {
      allow read: if isSignedIn() && userCanAccessLocation(resource.data.locationId);
      allow create, update: if canOperate() && userCanAccessLocation(request.resource.data.locationId);
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdminOrManager();
      allow create: if canOperate();
      allow update, delete: if isAdmin();
    }

    match /system_configs/{configId} {
      allow read: if canOperate();
      allow write: if isAdmin();
    }

    // Bloquea cualquier colección no prevista.
    // Phase 2: Customer cards subcollection
    match /customers/{customerId}/cards/{cardId} {
      allow read: if isSignedIn();
      allow create: if isAdminOrManager();
      allow update: if canOperate();
      allow delete: if isAdmin();
    }

    // Phase 3: Archive collections — read-only for admin
    match /sales_archive/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }
    match /auditLogs_archive/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /stockMovements_archive/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /inventory_movements_archive/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
