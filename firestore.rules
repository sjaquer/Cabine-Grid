rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Gets the user's role from their profile in the 'users' collection.
    // Caches the result for the request.
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Returns true if the user's role is 'admin'.
    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    // Returns true if the user's role is 'employee'.
    function isEmployee() {
      return isSignedIn() && getRole() == 'employee';
    }

    // User management:
    // Users can read their own profile.
    // Admins can read, list, and modify any user profile.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }

    // Machine management:
    // Any authenticated user (employee or admin) can view the machine list.
    // Only employees or admins can update a machine's state (start/end sessions).
    // Only admins can add or remove machines from the system.
    match /machines/{machineId} {
      allow read, list: if isSignedIn();
      allow update: if isEmployee() || isAdmin();
      allow create, delete: if isAdmin();
    }
    
    // Sales management:
    // Employees and admins can create new sales records.
    // Only admins can view the full sales history or modify/delete records.
    match /sales/{saleId} {
      allow create: if isEmployee() || isAdmin();
      allow read, list, update, delete: if isAdmin();
    }
  }
}
