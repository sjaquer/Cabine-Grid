rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userDocPath());
    }

    function getRole() {
      return hasUserProfile() ? get(userDocPath()).data.role : null;
    }

    function isAdmin() {
      return getRole() == 'admin';
    }

    function isManager() {
      return getRole() == 'manager';
    }

    function isOperator() {
      return getRole() == 'operator';
    }

    function isViewOnly() {
      return getRole() == 'view-only';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    function canOperate() {
      return isAdminOrManager() || isOperator();
    }

    function hasPrivilegedClearance() {
      return true;
    }

    function locationInScope(locationId) {
      return isAdminOrManager() || (
        isOperator() &&
        locationId is string &&
        get(userDocPath()).data.locationIds is list &&
        locationId in get(userDocPath()).data.locationIds
      );
    }

    function saleLooksValid() {
      return request.resource.data.amount is number &&
        request.resource.data.amount >= 0 &&
        request.resource.data.amount <= 5000 &&
        request.resource.data.totalMinutes is number &&
        request.resource.data.totalMinutes >= 0 &&
        request.resource.data.totalMinutes <= 1440;
    }

    function hasNonNegativeStock() {
      return request.resource.data.stock is number && request.resource.data.stock >= 0;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdminOrManager());
      allow list: if isAdminOrManager();

      // Permite bootstrap del perfil propio al iniciar sesión por primera vez.
      allow create: if isSignedIn() && (
        request.auth.uid == userId || (isAdminOrManager() && hasPrivilegedClearance())
      );

      // El propio usuario puede actualizar datos básicos (no rol).
      allow update: if isSignedIn() && (
        isAdminOrManager() ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role
        )
      );

      allow delete: if isAdmin() && hasPrivilegedClearance();
    }

    match /machines/{machineId} {
      allow read: if isSignedIn() && (
        isAdminOrManager() ||
        (isOperator() && resource.data.locationId is string && locationInScope(resource.data.locationId))
      );
      allow create, update, delete: if canOperate() && hasPrivilegedClearance() && (
        !('locationId' in request.resource.data) ||
        locationInScope(request.resource.data.locationId)
      );
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminOrManager() && hasPrivilegedClearance();
    }

    match /locations/{locationId} {
      allow read: if isSignedIn() && (
        isAdminOrManager() ||
        (isOperator() && locationInScope(locationId))
      );
      allow create, update, delete: if isAdminOrManager() && hasPrivilegedClearance();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn() && (
        isAdminOrManager() ||
        (isOperator() && resource.data.locationId is string && locationInScope(resource.data.locationId))
      );
      allow create: if canOperate() && saleLooksValid() && (
        !('locationId' in request.resource.data) ||
        locationInScope(request.resource.data.locationId)
      );
      allow update: if canOperate() && saleLooksValid() && (
        !('locationId' in request.resource.data) ||
        locationInScope(request.resource.data.locationId)
      );
      allow delete: if isAdminOrManager();
    }

    match /inventory/{inventoryId} {
      allow read: if isSignedIn() && (
        isAdminOrManager() ||
        (isOperator() && resource.data.locationId is string && locationInScope(resource.data.locationId))
      );
      allow create: if canOperate() && hasNonNegativeStock() && (
        request.resource.data.locationId is string && locationInScope(request.resource.data.locationId)
      );
      allow update: if canOperate() && hasNonNegativeStock() && (
        request.resource.data.locationId is string && locationInScope(request.resource.data.locationId)
      );
      allow delete: if canOperate() && hasPrivilegedClearance();
    }

    match /inventoryMovements/{movementId} {
      allow read: if isSignedIn() && (
        isAdminOrManager() ||
        (isOperator() && resource.data.locationId is string && locationInScope(resource.data.locationId))
      );
      allow create: if canOperate() && (
        request.resource.data.locationId is string &&
        locationInScope(request.resource.data.locationId) &&
        request.resource.data.quantity is number &&
        request.resource.data.quantity > 0 &&
        request.resource.data.quantity <= 200
      );
      allow update, delete: if isAdminOrManager() && hasPrivilegedClearance();
    }

    match /inventoryDiscrepancies/{discrepancyId} {
      allow read: if isSignedIn() && (
        isAdminOrManager() ||
        (isOperator() && resource.data.locationId is string && locationInScope(resource.data.locationId))
      );
      allow create: if canOperate() && (
        request.resource.data.locationId is string && locationInScope(request.resource.data.locationId)
      );
      allow update, delete: if isAdminOrManager() && hasPrivilegedClearance();
    }

    match /shiftClosures/{closureId} {
      allow read: if isAdminOrManager();
      allow create: if canOperate() && (
        request.resource.data.locationId == null ||
        (request.resource.data.locationId is string && locationInScope(request.resource.data.locationId))
      );
      allow update, delete: if isAdmin() && hasPrivilegedClearance();
    }

    match /receiptCounters/{counterId} {
      allow read: if isSignedIn();
      allow create, update: if canOperate();
      allow delete: if isAdmin() && hasPrivilegedClearance();
    }

    match /auditLogs/{logId} {
      allow read: if isAdminOrManager();
      allow create: if canOperate();
      allow update, delete: if isAdmin() && hasPrivilegedClearance();
    }

    match /sensitiveApprovals/{approvalId} {
      allow read: if isAdminOrManager();
      allow create: if canOperate() && (
        request.resource.data.locationId == null ||
        (request.resource.data.locationId is string && locationInScope(request.resource.data.locationId))
      );
      allow update: if isAdmin() && hasPrivilegedClearance();
      allow delete: if isAdmin() && hasPrivilegedClearance();
    }

    match /fraudAlerts/{alertId} {
      allow read: if isAdminOrManager();
      allow create: if canOperate();
      allow update, delete: if isAdmin() && hasPrivilegedClearance();
    }

    match /dailySnapshots/{snapshotId} {
      allow read: if isAdminOrManager();
      allow create, update, delete: if isAdmin() && hasPrivilegedClearance();
    }

    // Bloquea cualquier colección no prevista.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
